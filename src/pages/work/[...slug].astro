---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import EntryLayout from '../../layouts/EntryLayout.astro';
import { substituteYears } from '../../utils/experience';
import { buildEntrySchema } from '../../utils/schema';

interface Props {
	entry: CollectionEntry<'work'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const work = await getCollection('work');
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Plain text for SEO/meta tags; HTML variant carries the span the BaseLayout
// client script refreshes between deploys.
const descriptionText = substituteYears(entry.data.description);
const descriptionHtml = substituteYears(entry.data.description, { html: true });
const imgAlt = entry.data.img_alt || `${entry.data.title} project preview`;

const creativeWorkSchema = buildEntrySchema({
	type: 'CreativeWork',
	title: entry.data.title,
	description: descriptionText,
	urlPath: `/work/${entry.id}/`,
	publishDate: entry.data.publishDate,
	tags: entry.data.tags,
	imageSrc: entry.data.img.src,
	site: Astro.site!,
});
---

<EntryLayout
	title={entry.data.title}
	description={descriptionText}
	descriptionHtml={descriptionHtml}
	tags={entry.data.tags}
	img={entry.data.img}
	imgAlt={imgAlt}
	backHref="/work/"
	backLabel="Work"
	structuredData={creativeWorkSchema}
	ogImage={entry.data.img.src}
	ogImageAlt={imgAlt}
	publishDate={entry.data.publishDate}
>
	<Content />
</EntryLayout>
