---
import { type CollectionEntry, render } from 'astro:content';

import EntryLayout from '../../layouts/EntryLayout.astro';
import { getPublishedPosts } from '../../utils/collections';
import { substituteYears } from '../../utils/experience';
import { formatDate } from '../../utils/format';
import { buildEntrySchema } from '../../utils/schema';

interface Props {
	entry: CollectionEntry<'blog'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const blog = await getPublishedPosts();
	return blog.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const description = substituteYears(entry.data.description);
const descriptionHtml = substituteYears(entry.data.description, { html: true });
const imgAlt = entry.data.img_alt || `${entry.data.title} blog preview`;

const blogPostSchema = buildEntrySchema({
	type: 'BlogPosting',
	title: entry.data.title,
	description,
	urlPath: `/blog/${entry.id}/`,
	publishDate: entry.data.publishDate,
	updatedDate: entry.data.updatedDate,
	tags: entry.data.tags,
	imageSrc: entry.data.img?.src,
	site: Astro.site!,
});
---

<EntryLayout
	title={entry.data.title}
	description={description}
	descriptionHtml={descriptionHtml}
	tags={entry.data.tags}
	img={entry.data.img}
	imgAlt={entry.data.img ? imgAlt : undefined}
	backHref="/blog/"
	backLabel="Blog"
	structuredData={blogPostSchema}
	ogImage={entry.data.img?.src}
	ogImageAlt={entry.data.img ? imgAlt : undefined}
	publishDate={entry.data.publishDate}
>
	<div class="post-meta" slot="meta">
		<time class="publish-date" datetime={entry.data.publishDate.toISOString()}>
			Published: {formatDate(entry.data.publishDate)}
		</time>
		{entry.data.updatedDate && (
			<time class="updated-date" datetime={entry.data.updatedDate.toISOString()}>
				Updated: {formatDate(entry.data.updatedDate)}
			</time>
		)}
	</div>
	<Content />
</EntryLayout>

<style>
	.post-meta {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin-bottom: 1rem;
		max-width: 100%;
		overflow-wrap: break-word;
	}

	.publish-date,
	.updated-date {
		font-weight: 500;
		text-decoration: none;
	}

	@media (min-width: 50em) {
		.post-meta {
			flex-direction: row;
			gap: 1rem;
		}
	}
</style>
