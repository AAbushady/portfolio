---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Pill from './Pill.astro';
import { formatDate } from '../utils/format';

interface Props {
	post: CollectionEntry<'blog'>;
	/** Heading level for the post title, matched to the page's outline. */
	headingLevel?: 'h2' | 'h3';
}

const { data, id } = Astro.props.post;
const Heading = Astro.props.headingLevel ?? 'h3';
---

<article class="card">
	<div class="content">
		<Heading class="title"><a href={`/blog/${id}/`}>{data.title}</a></Heading>
		<div class="tags">
			{data.tags.map((tag) => (
				<Pill>{tag}</Pill>
			))}
		</div>
		<p class="description">{data.description}</p>
		<div class="meta">
			<time datetime={data.publishDate.toISOString()}>Published: {formatDate(data.publishDate)}</time>
			{data.updatedDate && (
				<time datetime={data.updatedDate.toISOString()}>Updated: {formatDate(data.updatedDate)}</time>
			)}
		</div>
	</div>
	{data.img && (
		<Image
			src={data.img}
			alt={data.img_alt || `Preview of ${data.title}`}
			widths={[480, 960]}
			sizes="(min-width: 50em) 30vw, 90vw"
		/>
	)}
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--theme-transition);
		height: 100%;
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	.content {
		padding: 1.5rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.title {
		margin: 0;
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 500;
	}

	.title a {
		color: var(--gray-0);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.title a:hover {
		color: var(--accent-regular);
	}

	.description {
		margin: 0;
		color: var(--gray-300);
		font-size: var(--text-sm);
		line-height: 1.4;
		flex-grow: 1;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}


	.tags {
		display: flex;
		gap: 0.375rem;
		flex-wrap: wrap;
	}

	.tags :global(.pill) {
		font-size: var(--text-xs);
		padding: 0.25rem 0.75rem;
	}

	img {
		width: 100%;
		height: 12rem;
		object-fit: cover;
	}

	@media (min-width: 50em) {
		.card {
			border-radius: 1.5rem;
		}

		img {
			height: 16rem;
		}
	}
</style>
