---
import Icon from './Icon.astro';
---

<theme-toggle>
	<button>
		<span class="sr-only">Toggle dark theme</span>
		<span class="icon light"><Icon icon="sun" /></span>
		<span class="icon dark"><Icon icon="moon-stars" /></span>
	</button>
</theme-toggle>

<style>
	button {
		display: flex;
		border: 0;
		border-radius: 999rem;
		padding: 0;
		background-color: var(--gray-999);
		box-shadow: inset 0 0 0 1px var(--accent-overlay);
		cursor: pointer;
	}

	.icon {
		z-index: 1;
		position: relative;
		display: flex;
		padding: 0.5rem;
		width: 2rem;
		height: 2rem;
		font-size: 1rem;
		/* gray-300, not accent-overlay: the inactive icon sits on gray-999 and
		   needs >= 3:1 contrast (WCAG 1.4.11). */
		color: var(--gray-300);
	}

	.icon.light::before {
		content: '';
		z-index: -1;
		position: absolute;
		inset: 0;
		background-color: var(--accent-regular);
		border-radius: 999rem;
	}

	:global(.theme-dark) .icon.light::before {
		transform: translateX(100%);
	}

	:global(.theme-dark) .icon.dark,
	:global(html:not(.theme-dark)) .icon.light,
	button[aria-pressed='false'] .icon.light {
		color: var(--accent-text-over);
	}

	@media (prefers-reduced-motion: no-preference) {
		.icon,
		.icon.light::before {
			transition:
				transform var(--theme-transition),
				color var(--theme-transition);
		}
	}

	@media (forced-colors: active) {
		.icon.light::before {
			background-color: SelectedItem;
		}
	}
</style>

<script>
	class ThemeToggle extends HTMLElement {
		constructor() {
			super();

			const button = this.querySelector('button')!;

			/** Set the theme to dark/light mode. */
			const setTheme = (dark: boolean) => {
				document.documentElement.classList[dark ? 'add' : 'remove']('theme-dark');
				button.setAttribute('aria-pressed', String(dark));
			};

			// Toggle the theme when a user clicks the button. Only this explicit
			// choice is persisted; storage can throw (e.g. cookies blocked), in
			// which case the theme still applies for the current page view.
			button.addEventListener('click', () => {
				const dark = !this.isDark();
				setTheme(dark);
				try {
					localStorage.setItem('theme', dark ? 'dark' : 'light');
				} catch {}
			});

			// Initialize button state to reflect current theme.
			setTheme(this.isDark());

			// Keep aria-pressed in sync when the OS theme flips for visitors
			// without a stored choice (the head script updates the class first;
			// listeners run in registration order).
			window
				.matchMedia('(prefers-color-scheme: dark)')
				.addEventListener('change', () => setTheme(this.isDark()));
		}

		isDark() {
			return document.documentElement.classList.contains('theme-dark');
		}
	}
	customElements.define('theme-toggle', ThemeToggle);
</script>
