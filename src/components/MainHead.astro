---
import '../styles/global.css';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
	structuredData?: object | undefined;
	ogImage?: string | undefined;
	ogImageAlt?: string | undefined;
	ogType?: string | undefined;
	publishDate?: Date | undefined;
}

const {
	title = 'Alex Abushady: Portfolio',
	description = 'Alex Abushady is a Full stack software engineer exploring game development through Unity, game modding, and backend systems. Building tools and interactive experiences',
	structuredData,
	ogImage = '/assets/og-default.jpg',
	ogImageAlt = 'Alex Abushady - Software Engineer Portfolio',
	ogType = 'website',
	publishDate,
} = Astro.props;

// The default OG image is generated at exactly 1200x630; per-page images vary,
// so only claim dimensions when serving the default.
const isDefaultOgImage = !Astro.props.ogImage;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<meta charset="UTF-8" />
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content="Alex Abushady" />
<meta http-equiv="content-language" content="en-US">
<title>{title}</title>

<!-- Open Graph Tags -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:site_name" content="Alex Abushady" />
<meta property="og:locale" content="en_US" />
<meta name="image" property="og:image" content={ogImageURL.href} />
{isDefaultOgImage && (
	<meta property="og:image:width" content="1200" />
	<meta property="og:image:height" content="630" />
)}
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:author" content="Alex Abushady" />

<!-- Article-specific meta tags -->
{ogType === 'article' && publishDate && (
	<meta property="article:published_time" content={publishDate.toISOString()} />
	<meta property="article:author" content="Alex Abushady" />
)}

<!-- Twitter Card Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL.href} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL.href} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preload" href="/fonts/public-sans-400.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/rubik-600.woff2" as="font" type="font/woff2" crossorigin />

<!-- JSON-LD structured data for Person schema -->
<script is:inline type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Alex Abushady",
  "jobTitle": "Software Engineer",
  "url": "https://alexabushady.com",
  "sameAs": [
    "https://github.com/AAbushady",
    "https://linkedin.com/in/alexabushady",
    "https://x.com/Epiculous214"
  ],
  "knowsAbout": [
    "Software Engineering",
    "Machine Learning",
    "Large Language Models",
    "Python",
    "JavaScript",
    "React",
    "Node.js",
    "Data Science",
    "C#",
    "Video Games"
  ],
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "St. Petersburg College"
  },
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Software Engineer",
    "occupationLocation": {
      "@type": "Place",
      "name": "United States"
    }
  }
}
</script>

{structuredData && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
)}

<script is:inline>
	// This code is inline in the head to make dark mode instant & blocking.
	const getThemePreference = () => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	};
	const isDark = getThemePreference() === 'dark';
	document.documentElement.classList[isDark ? 'add' : 'remove']('theme-dark');

	if (typeof localStorage !== 'undefined') {
		// Watch the document element and persist user preference when it changes.
		const observer = new MutationObserver(() => {
			const isDark = document.documentElement.classList.contains('theme-dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		});
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
	}
</script>
