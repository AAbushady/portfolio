---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { iconPaths } from './IconPaths';

/** Main menu items */
const textLinks: { label: string; href: string }[] = [
	{ label: 'Home', href: '/' },
	{ label: 'Work', href: '/work/' },
	{ label: 'Blog', href: '/blog/' },
	{ label: 'About', href: '/about/' },
];

/** Icon links to social media */
const iconLinks: { label: string; href: string; icon: keyof typeof iconPaths }[] = [
	{ label: 'GitHub', href: 'https://github.com/AAbushady', icon: 'github-logo' },
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/in/alexabushady/', icon: 'linkedin-logo' },
	{ label: 'X', href: 'https://x.com/Epiculous214', icon: 'twitter-logo' },
	{ label: 'Huggingface', href: 'https://huggingface.co/Epiculous', icon: 'huggingface-logo' },
];

/** aria-current value for a nav link: 'page' for the exact page, 'true' for an ancestor section. */
const ariaCurrent = (href: string): 'page' | 'true' | null => {
	let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
	if (pathname.at(0) !== '/') pathname = '/' + pathname;
	if (pathname.at(-1) !== '/') pathname += '/';
	if (pathname === href) return 'page';
	if (href !== '/' && pathname.startsWith(href)) return 'true';
	return null;
};
---

<nav>
	<div class="menu-header">
		<a href="/" class="site-title">
			<Icon icon="terminal-window" size="1.6em" gradient />
			Alex Abushady
		</a>
		<menu-button>
			<button class="menu-button" aria-expanded="false" aria-controls="menu-content">
				<span class="sr-only">Menu</span>
				<Icon icon="list" />
			</button>
		</menu-button>
	</div>
	<div id="menu-content" class="menu-content">
		<ul class="nav-items">
			{
				textLinks.map(({ label, href }) => (
					<li>
						<a aria-current={ariaCurrent(href)} class="link" href={href}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
		<div class="menu-footer">
			<div class="socials">
				{
					iconLinks.map(({ href, icon, label }) => (
						<a href={href} class="social">
							<span class="sr-only">{label}</span>
							<Icon icon={icon} />
						</a>
					))
				}
			</div>

			<div class="theme-toggle">
				<ThemeToggle />
			</div>
		</div>
	</div>
</nav>

<script>
	// Visibility is CSS-driven: without JS the menu renders in the page flow,
	// and `html.js` (set inline in MainHead) collapses it into this button.
	class MenuButton extends HTMLElement {
		constructor() {
			super();

			const btn = this.querySelector('button')!;
			const menu = document.getElementById('menu-content')!;

			/** Set whether the menu is currently expanded or collapsed. */
			const setExpanded = (expand: boolean) => {
				btn.setAttribute('aria-expanded', expand ? 'true' : 'false');
				menu.classList.toggle('open', expand);
			};

			// Toggle menu visibility when the menu button is clicked.
			btn.addEventListener('click', () => setExpanded(!menu.classList.contains('open')));

			// Close with Escape and hand focus back to the button.
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && menu.classList.contains('open')) {
					setExpanded(false);
					btn.focus();
				}
			});

			// Reset the mobile state when crossing into the desktop layout,
			// where CSS shows the menu inline and hides this button.
			const mediaQueries = window.matchMedia('(min-width: 50em)');
			const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
				if (e.matches) setExpanded(false);
			};
			handleViewports(mediaQueries);
			mediaQueries.addEventListener('change', handleViewports);
		}
	}
	customElements.define('menu-button', MenuButton);
</script>

<style>
	nav {
		z-index: 9999;
		position: relative;
		font-family: var(--font-brand);
		font-weight: 500;
		margin-bottom: 3.5rem;
	}

	.menu-header {
		display: flex;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 1.5rem;
	}

	.site-title {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		line-height: 1.1;
		color: var(--gray-0);
		text-decoration: none;
	}

	/* The button can only operate the menu when JS runs; without it the menu
	   renders in the page flow, so the button stays hidden. */
	.menu-button {
		position: relative;
		display: none;
		border: 0;
		border-radius: 999rem;
		padding: 0.5rem;
		font-size: 1.5rem;
		color: var(--gray-300);
		background: radial-gradient(var(--gray-900), var(--gray-800) 150%);
		box-shadow: var(--shadow-md);
	}

	.menu-button[aria-expanded='true'] {
		color: var(--gray-0);
		background:
			linear-gradient(180deg, var(--gray-600), transparent),
			radial-gradient(var(--gray-900), var(--gray-800) 150%);
	}

	:global(html.js) .menu-button {
		display: flex;
	}

	.menu-button::before {
		position: absolute;
		inset: -1px;
		content: '';
		background: var(--gradient-stroke);
		border-radius: 999rem;
		z-index: -1;
	}

	/* Collapsed by default only when JS can expand it again; the class is set
	   inline in MainHead before first paint, so there is no open-menu flash. */
	:global(html.js) .menu-content {
		display: none;
	}

	:global(html.js) .menu-content.open {
		display: block;
		position: absolute;
		left: 0;
		right: 0;
	}

	.nav-items {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		font-size: var(--text-md);
		line-height: 1.2;
		list-style: none;
		padding: 2rem;
		background-color: var(--gray-999);
		border-bottom: 1px solid var(--gray-800);
	}

	.link {
		display: inline-block;
		color: var(--gray-300);
		text-decoration: none;
	}

	.link[aria-current] {
		color: var(--gray-0);
	}

	.menu-footer {
		--icon-size: var(--text-xl);
		--icon-padding: 0.5rem;

		display: flex;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 1.5rem 2rem 1.5rem 1.5rem;
		background-color: var(--gray-999);
		border-radius: 0 0 0.75rem 0.75rem;
		box-shadow: var(--shadow-lg);
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.625rem;
		font-size: var(--icon-size);
	}

	.social {
		display: flex;
		padding: var(--icon-padding);
		text-decoration: none;
		color: var(--accent-dark);
		transition: color var(--theme-transition);
	}

	.social:hover,
	.social:focus {
		color: var(--accent-text-over);
	}

	.theme-toggle {
		display: flex;
		align-items: center;
		height: calc(var(--icon-size) + 2 * var(--icon-padding));
	}

	/* The toggle is a JS control; don't render a dead button without it. */
	:global(html:not(.js)) .theme-toggle {
		display: none;
	}

	@media (min-width: 50em) {
		nav {
			display: grid;
			grid-template-columns: 1fr auto 1fr;
			align-items: center;
			padding: 2.5rem 5rem;
			gap: 1rem;
		}

		.menu-header {
			padding: 0;
		}

		.site-title {
			font-size: var(--text-lg);
		}

		/* Beat the mobile collapsed/open rules regardless of JS state. */
		.menu-content,
		:global(html.js) .menu-content,
		:global(html.js) .menu-content.open {
			display: contents;
			position: static;
		}

		:global(html.js) .menu-button {
			display: none;
		}

		.nav-items {
			position: relative;
			flex-direction: row;
			font-size: var(--text-sm);
			border-radius: 999rem;
			border: 0;
			padding: 0.5rem 0.5625rem;
			background: radial-gradient(var(--gray-900), var(--gray-800) 150%);
			box-shadow: var(--shadow-md);
		}

		.nav-items::before {
			position: absolute;
			inset: -1px;
			content: '';
			background: var(--gradient-stroke);
			border-radius: 999rem;
			z-index: -1;
		}

		.link {
			padding: 0.5rem 1rem;
			border-radius: 999rem;
			transition:
				color var(--theme-transition),
				background-color var(--theme-transition);
		}

		.link:hover,
		.link:focus {
			color: var(--gray-100);
			background-color: var(--accent-subtle-overlay);
		}

		.link[aria-current] {
			color: var(--accent-text-over);
			background-color: var(--accent-regular);
		}

		.menu-footer {
			--icon-padding: 0.375rem;

			justify-self: flex-end;
			align-items: center;
			padding: 0;
			background-color: transparent;
			box-shadow: none;
		}

		.socials {
			display: none;
		}
	}

	@media (min-width: 60em) {
		.socials {
			display: flex;
			justify-content: flex-end;
			gap: 0;
		}
	}
	@media (forced-colors: active) {
		.link[aria-current] {
			color: SelectedItem;
		}
	}
</style>
