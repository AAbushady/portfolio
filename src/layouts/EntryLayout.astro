---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

import BaseLayout from './BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';

/**
 * Shared shell for work-project and blog-post detail pages.
 * Default slot: the rendered markdown `<Content />`.
 * Named slot `meta`: optional block rendered above the tags (e.g. blog dates);
 * slotted markup keeps the page's own style scope, so style it page-side.
 */
interface Props {
	title: string;
	/** Plain-text description for meta tags. */
	description: string;
	/** Optional HTML variant of the description for the visible hero. */
	descriptionHtml?: string | undefined;
	tags: string[];
	img?: ImageMetadata | undefined;
	imgAlt?: string | undefined;
	backHref: string;
	backLabel: string;
	structuredData: object;
	ogImage?: string | undefined;
	ogImageAlt?: string | undefined;
	publishDate: Date;
}

const {
	title,
	description,
	descriptionHtml,
	tags,
	img,
	imgAlt,
	backHref,
	backLabel,
	structuredData,
	ogImage,
	ogImageAlt,
	publishDate,
} = Astro.props;
---

<BaseLayout
	title={title}
	description={description}
	structuredData={structuredData}
	ogImage={ogImage}
	ogImageAlt={ogImageAlt}
	ogType="article"
	publishDate={publishDate}
>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href={backHref}><Icon icon="arrow-left" /> {backLabel}</a>
					<Hero title={title} align="start">
						<slot name="meta" />
						<div class="details">
							<div class="tags">
								{tags.map((t) => <Pill>{t}</Pill>)}
							</div>
							{descriptionHtml ? (
								<p class="description" set:html={descriptionHtml} />
							) : (
								<p class="description">{description}</p>
							)}
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					{img && (
						<Image
							src={img}
							alt={imgAlt ?? `${title} preview`}
							widths={[720, 1440]}
							sizes="(min-width: 50em) 65ch, 100vw"
							loading="eager"
							fetchpriority="high"
						/>
					)}
					<div class="content">
						<slot />
					</div>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<script>
	// Demo videos replace GIFs and autoplay like them; for users who prefer
	// reduced motion, stop the autoplay and surface the native controls
	// instead. Runs again on `change` so enabling the OS setting mid-visit
	// stops the videos without a reload.
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	const stopAutoplay = () => {
		if (!reducedMotion.matches) return;
		for (const video of document.querySelectorAll('video')) {
			if (video.autoplay || !video.paused) {
				video.removeAttribute('autoplay');
				video.pause();
				video.controls = true;
			}
		}
	};

	stopAutoplay();
	reducedMotion.addEventListener('change', stopAutoplay);
</script>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.content {
		max-width: min(65ch, 100%);
		margin-inline: auto;
		padding: 0 1rem;
	}

	.content > :global(* + *) {
		margin-top: 1rem;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4),
	.content :global(h5) {
		margin: 1.5rem 0;
		word-wrap: break-word;
		overflow-wrap: break-word;
		hyphens: auto;
	}

	.content :global(img),
	.content :global(video) {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	.content :global(video) {
		width: 100%;
		height: auto;
	}

	.content :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.1;
		padding-inline-start: 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		color: var(--gray-0);
	}

	.back-link,
	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.back-link:hover,
	.back-link:focus,
	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.details {
			flex-direction: row;
			gap: 2.5rem;
		}

		.content :global(blockquote) {
			font-size: var(--text-2xl);
		}
	}
</style>
